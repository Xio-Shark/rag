# 默认最简模式可直接使用 sqlite:///./rag_qa_bench.db
# 如需使用 docker-compose 提供的 PostgreSQL，请保留下面的 DATABASE_URL 配置
APP_NAME=RAG QA Bench
APP_ENV=development
APP_LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_qa_bench
DOCS_DIR=data/docs
EVALS_DIR=data/evals
EVAL_SNAPSHOTS_DIR=data/evals/snapshots
EVAL_REPORTS_DIR=output/evals
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_BACKEND=hash
EMBEDDING_DIMENSIONS=64
GENERATOR_MODEL_NAME=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
TOP_K=3
RETRIEVAL_CANDIDATE_K=20
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RETRIEVAL_THRESHOLD=0.15
MIN_EVIDENCE_CHUNKS=1
MAX_FILE_SIZE_BYTES=10485760
PROMPT_VERSION=v1
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=1
OPENAI_MAX_COST_USD=2.0
FEATURE_EVALS_ENABLED=true
FEATURE_REPLAY_EXPERIMENTS_ENABLED=true
